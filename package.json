{
  "name": "shwtracker",
  "version": "1.0.0",
  "description": "Maplestory Daily/Weekly Task Tracker",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "build": {
    "appId": "com.shwtracker.app",
    "productName": "shwTracker",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "style.css",
      "renderer.js",
      "bossData.json",
      "purple_crystal.png",
      "yellow_crystal.png",
      "characters/**/*"
    ],
    "extraResources": [
      {
        "from": "characters",
        "to": "characters",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "bossData.json",
        "to": "bossData.json"
      },
      {
        "from": "purple_crystal.png",
        "to": "icons/purple_crystal.png"
      },
      {
        "from": "yellow_crystal.png",
        "to": "icons/yellow_crystal.png"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "shwTracker"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  }
}
